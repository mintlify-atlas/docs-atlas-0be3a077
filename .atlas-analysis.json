  "keyFeatures": [
    "In-memory key-value store with Redis compatibility",
    "RDB persistence for data durability",
    "Master-slave replication for high availability",
    "Event-driven streams for real-time data flows",
    "ACID transactions with MULTI/EXEC",
    "Key expiration with TTL support",
    "RESP protocol implementation",
    "Compatible with redis-cli"
  ],
  "publicApiSurface": [
    "SET key value [PX milliseconds]",
    "GET key",
    "DEL key",
    "INCR key",
    "EXPIRE key seconds",
    "XADD stream ID field value [field value ...]",
    "XRANGE stream start end",
    "XREAD [BLOCK milliseconds] STREAMS key [key ...] ID [ID ...]",
    "MULTI",
    "EXEC",
    "DISCARD",
    "PING",
    "ECHO message",
    "CONFIG GET parameter",
    "KEYS pattern",
    "INFO [section]",
    "TYPE key",
    "REPLCONF",
    "PSYNC replicationid offset",
    "WAIT numreplicas timeout"
  ]
